<!-- navbar -->
<nav class="px-4 md:px-10 flex items-center justify-between py-3 bg-white shadow-sm relative z-40">
  <!-- Logo -->
  <a href="/">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 155 40" height="38">
      <path
        d="M17,2 C13,8 9,16 13,23 C14,27 17,29 17,35 C21,30 23,25 19,19 C21,23 25,24 23,30 C27,24 27,14 21,9 C21,15 19,19 17,19 C15,13 17,8 17,2 Z"
        fill="#FE5F1E"
      />
      <text x="34" y="29" font-family="Lato, sans-serif" font-weight="900" font-size="25">
        <tspan fill="#232323">Feast</tspan>
        <tspan fill="#FE5F1E">Fly</tspan>
      </text>
    </svg>
  </a>

  <!-- Desktop nav links -->
  <ul class="hidden md:flex items-center">
    <li class="ml-6"><a href="/">Menu</a></li>
    <li class="ml-6"><a href="/offers">Offers</a></li>
    <% if(user) { %> <% if(locals.isAdmin) { %>
    <li class="ml-6"><a href="/admin/orders">Orders</a></li>
    <li class="ml-6"><a href="/admin/items">Items</a></li>
    <% } else { %>
    <li class="ml-6"><a href="/customer/order">My Orders</a></li>
    <li class="ml-6"><a href="/customer/profile">Profile</a></li>
    <% } %>
    <li class="ml-6">
      <form id="logout" action="/logout" method="post">
        <span
          onclick="
            event.preventDefault();
            document.getElementById('logout').submit();
          "
          class="cursor-pointer"
          >Logout</span
        >
      </form>
    </li>
    <% } else { %>
    <li class="ml-6"><a href="/register">Register</a></li>
    <li class="ml-6"><a href="/login">Login</a></li>
    <% } %>
    <li class="ml-6">
      <a href="/cart" class="inline-flex px-4 py-2 rounded-full items-center"
        ><span id="cartCounter" class="text-white font-bold rounded-full pr-2"
          ><%= session.cart ? session.cart.totalQty : '' %></span
        ><img src="/img/cart.png" alt="cart"
      /></a>
    </li>
  </ul>

  <!-- Mobile: cart icon + hamburger -->
  <div class="flex items-center gap-3 md:hidden">
    <a href="/cart" class="inline-flex items-center px-3 py-1.5 rounded-full bg-orange-500">
      <span class="text-white font-bold text-sm pr-1"
        ><%= session.cart ? session.cart.totalQty : '0' %></span
      >
      <img src="/img/cart.png" alt="cart" class="h-5 w-5" />
    </a>
    <button
      id="nav-toggle"
      class="p-1.5 rounded-md text-gray-700 hover:bg-gray-100"
      aria-label="Menu"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"
        />
      </svg>
    </button>
  </div>

  <!-- Mobile dropdown -->
  <div
    id="mobile-menu"
    class="hidden absolute top-full left-0 right-0 bg-white shadow-lg border-t border-gray-100 z-50"
  >
    <ul class="flex flex-col px-4 py-3 space-y-1">
      <li><a href="/" class="block py-2 px-3 rounded-lg hover:bg-gray-50">Menu</a></li>
      <li><a href="/offers" class="block py-2 px-3 rounded-lg hover:bg-gray-50">Offers</a></li>
      <% if(user) { %> <% if(locals.isAdmin) { %>
      <li>
        <a href="/admin/orders" class="block py-2 px-3 rounded-lg hover:bg-gray-50">Orders</a>
      </li>
      <li><a href="/admin/items" class="block py-2 px-3 rounded-lg hover:bg-gray-50">Items</a></li>
      <% } else { %>
      <li>
        <a href="/customer/order" class="block py-2 px-3 rounded-lg hover:bg-gray-50">My Orders</a>
      </li>
      <li>
        <a href="/customer/profile" class="block py-2 px-3 rounded-lg hover:bg-gray-50">Profile</a>
      </li>
      <% } %>
      <li>
        <form id="logout-mobile" action="/logout" method="post">
          <span
            onclick="
              event.preventDefault();
              document.getElementById('logout-mobile').submit();
            "
            class="block py-2 px-3 rounded-lg hover:bg-gray-50 cursor-pointer text-red-500"
            >Logout</span
          >
        </form>
      </li>
      <% } else { %>
      <li><a href="/register" class="block py-2 px-3 rounded-lg hover:bg-gray-50">Register</a></li>
      <li><a href="/login" class="block py-2 px-3 rounded-lg hover:bg-gray-50">Login</a></li>
      <% } %>
    </ul>
  </div>
</nav>

<script>
  (function () {
    var toggle = document.getElementById('nav-toggle');
    var menu = document.getElementById('mobile-menu');
    if (toggle) {
      toggle.addEventListener('click', function () {
        menu.classList.toggle('hidden');
      });
    }
  })();
</script>
