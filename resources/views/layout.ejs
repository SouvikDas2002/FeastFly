<script>
(function () {
  var el = document.getElementById('location-text');
  if (!el) return;

  var CACHE_KEY = 'ff_location';
  var CACHE_TIME_KEY = 'ff_location_ts';
  var TTL = 10 * 60 * 1000; // 10 minutes

  var cached = localStorage.getItem(CACHE_KEY);
  var ts = parseInt(localStorage.getItem(CACHE_TIME_KEY) || '0', 10);
  if (cached && Date.now() - ts < TTL) {
    el.textContent = cached;
    return;
  }

  if (!navigator.geolocation) {
    el.textContent = 'Location unavailable';
    return;
  }

  navigator.geolocation.getCurrentPosition(
    function (pos) {
      var lat = pos.coords.latitude;
      var lon = pos.coords.longitude;
      fetch('https://nominatim.openstreetmap.org/reverse?format=json&lat=' + lat + '&lon=' + lon, {
        headers: { 'Accept-Language': 'en' }
      })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          var addr = data.address || {};
          var place = addr.neighbourhood || addr.suburb || addr.village || addr.town || addr.city || addr.county || '';
          var state = addr.state || '';
          var pin   = addr.postcode || '';
          var country = addr.country || '';
          var parts = [place];
          if (state) parts.push(state);
          if (pin)   parts.push(pin);
          if (country) parts.push(country);
          var label = parts.join(', ');
          el.textContent = label;
          localStorage.setItem(CACHE_KEY, label);
          localStorage.setItem(CACHE_TIME_KEY, Date.now().toString());
        })
        .catch(function () { el.textContent = ''; });
    },
    function () { el.textContent = ''; },
    { timeout: 8000 }
  );
}());
</script>
