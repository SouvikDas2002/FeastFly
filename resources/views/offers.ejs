<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FeastFly | Offers & Deals</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@100;300;400;500;600;700&family=Lato:ital,wght@0,400;0,700;1,400;1,900&family=Lora:ital,wght@1,400;1,500;1,600&family=Urbanist:wght@100&family=Varela&family=Varela+Round&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/tailwindcss/2.2.19/tailwind.min.css"
      integrity="sha512-wnea99uKIC3TJF7v4eKk4Y+lMz2Mklv18+r4na2Gn1abDRPPOeef95xTzdwGD9e6zXJBteMIhZ1+68QC5byJZw=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <link rel="stylesheet" href="/css/app.css" />
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css" />
    <style>
      .coupon-card {
        position: relative;
        background: #fff;
        border-radius: 12px;
        overflow: hidden;
      }
      .coupon-card::before,
      .coupon-card::after {
        content: '';
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        width: 20px;
        height: 20px;
        background: #f3f4f6;
        border-radius: 50%;
        z-index: 1;
      }
      .coupon-card::before { left: -10px; }
      .coupon-card::after  { right: -10px; }
      .coupon-divider {
        border-left: 2px dashed #e5e7eb;
      }
    </style>
  </head>
  <body>
    <%- include("layout.ejs") %>

    <!-- Hero Banner -->
    <section class="bg-gradient-to-r from-orange-500 to-red-500 py-10 px-4 md:px-10 text-white">
      <div class="container mx-auto text-center">
        <p class="text-sm font-semibold uppercase tracking-widest opacity-80 mb-2">Limited Time</p>
        <h1 class="text-3xl md:text-5xl font-extrabold mb-3">Today's Best Deals</h1>
        <p class="text-base md:text-lg opacity-90">Use a coupon below or grab a featured item at a special price.</p>
      </div>
    </section>

    <!-- Coupons Section -->
    <section class="py-10 px-4 md:px-10 bg-gray-50">
      <div class="container mx-auto">
        <h2 class="text-xl font-bold text-gray-800 mb-6">Coupon Codes</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">

          <!-- Coupon 1 -->
          <div class="coupon-card shadow-md flex overflow-hidden">
            <div class="bg-orange-500 flex items-center justify-center px-4">
              <span class="text-white font-extrabold text-lg tracking-widest rotate-180" style="writing-mode:vertical-rl">FIRST</span>
            </div>
            <div class="coupon-divider mx-0"></div>
            <div class="flex-1 p-4">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">New Users</p>
              <p class="text-2xl font-extrabold text-gray-800">50% OFF</p>
              <p class="text-xs text-gray-500 mt-1 mb-3">On your first order. Max discount ₹100.</p>
              <div class="border border-dashed border-orange-400 rounded px-3 py-1.5 text-center">
                <span class="font-bold text-orange-500 tracking-widest text-sm">FIRST50</span>
              </div>
            </div>
          </div>

          <!-- Coupon 2 -->
          <div class="coupon-card shadow-md flex overflow-hidden">
            <div class="bg-green-500 flex items-center justify-center px-4">
              <span class="text-white font-extrabold text-lg tracking-widest rotate-180" style="writing-mode:vertical-rl">FLAT</span>
            </div>
            <div class="coupon-divider mx-0"></div>
            <div class="flex-1 p-4">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">All Users</p>
              <p class="text-2xl font-extrabold text-gray-800">₹60 OFF</p>
              <p class="text-xs text-gray-500 mt-1 mb-3">On orders above ₹299. Valid all day.</p>
              <div class="border border-dashed border-green-500 rounded px-3 py-1.5 text-center">
                <span class="font-bold text-green-600 tracking-widest text-sm">FEAST60</span>
              </div>
            </div>
          </div>

          <!-- Coupon 3 -->
          <div class="coupon-card shadow-md flex overflow-hidden">
            <div class="bg-purple-500 flex items-center justify-center px-4">
              <span class="text-white font-extrabold text-lg tracking-widest rotate-180" style="writing-mode:vertical-rl">BOGO</span>
            </div>
            <div class="coupon-divider mx-0"></div>
            <div class="flex-1 p-4">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Weekend Special</p>
              <p class="text-2xl font-extrabold text-gray-800">Buy 2 Get 1</p>
              <p class="text-xs text-gray-500 mt-1 mb-3">On selected combos. Sat & Sun only.</p>
              <div class="border border-dashed border-purple-400 rounded px-3 py-1.5 text-center">
                <span class="font-bold text-purple-500 tracking-widest text-sm">BOGOFEAST</span>
              </div>
            </div>
          </div>

          <!-- Coupon 4 -->
          <div class="coupon-card shadow-md flex overflow-hidden">
            <div class="bg-red-500 flex items-center justify-center px-4">
              <span class="text-white font-extrabold text-lg tracking-widest rotate-180" style="writing-mode:vertical-rl">FREE</span>
            </div>
            <div class="coupon-divider mx-0"></div>
            <div class="flex-1 p-4">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Delivery</p>
              <p class="text-2xl font-extrabold text-gray-800">Free Delivery</p>
              <p class="text-xs text-gray-500 mt-1 mb-3">On orders above ₹199. No min items.</p>
              <div class="border border-dashed border-red-400 rounded px-3 py-1.5 text-center">
                <span class="font-bold text-red-500 tracking-widest text-sm">FREEDEL</span>
              </div>
            </div>
          </div>

        </div>

        <p class="text-xs text-gray-400 mt-4">* Coupons are promotional. Apply at checkout. T&C apply.</p>
      </div>
    </section>

    <!-- Featured Deals (popular items) -->
    <section class="py-10 px-4 md:px-10">
      <div class="container mx-auto">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-xl font-bold text-gray-800">Featured Deals</h2>
          <a href="/" class="text-orange-500 text-sm font-semibold hover:underline">View full menu →</a>
        </div>

        <% if(popularItems.length === 0) { %>
        <div class="text-center py-16 text-gray-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-14 w-14 mx-auto mb-4 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
          </svg>
          <p class="text-lg font-semibold">No featured deals right now</p>
          <p class="text-sm mt-1">Check back soon — new deals drop every day!</p>
          <a href="/" class="mt-5 inline-block btn-primary px-6 py-2 rounded-full text-white font-bold text-sm">Browse Menu</a>
        </div>
        <% } else { %>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
          <% popularItems.forEach(function(item) { %>
          <%
            const originalPrice = Math.round(item.price * 1.25);
            const discountPct  = 20;
          %>
          <div class="bg-white rounded-xl shadow-sm overflow-hidden relative">
            <!-- Discount badge -->
            <div class="absolute top-3 left-3 z-10 bg-orange-500 text-white text-xs font-bold px-2 py-1 rounded-full">
              <%= discountPct %>% OFF
            </div>
            <!-- Veg/Non-veg dot -->
            <div class="absolute top-3 right-3 z-10 w-4 h-4 rounded border-2 <%= item.isVeg === false ? 'border-red-600' : 'border-green-600' %> flex items-center justify-center bg-white">
              <div class="w-2 h-2 rounded-sm <%= item.isVeg === false ? 'bg-red-600' : 'bg-green-600' %>"></div>
            </div>
            <img src="/img/<%= item.image %>" alt="<%= item.name %>" class="w-full h-44 object-cover" />
            <div class="p-4">
              <h3 class="font-semibold text-gray-800 truncate mb-1"><%= item.name %></h3>
            <p class="text-xs text-gray-400 mb-1"><%= item.grams %>g &nbsp;·&nbsp; <%= item.calories %> kcal</p>
            <%
              const full  = Math.floor(item.rating);
              const half  = (item.rating - full) >= 0.5 ? 1 : 0;
              const empty = 5 - full - half;
            %>
            <div class="flex items-center gap-0.5 mb-2">
              <% for(let i=0;i<full;i++) { %>
                <svg class="w-3 h-3 text-orange-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <% } %>
              <% if(half) { %>
                <svg class="w-3 h-3" viewBox="0 0 20 20"><defs><linearGradient id="oh-<%=item._id%>"><stop offset="50%" stop-color="#fb923c"/><stop offset="50%" stop-color="#d1d5db"/></linearGradient></defs><path fill="url(#oh-<%=item._id%>)" d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <% } %>
              <% for(let i=0;i<empty;i++) { %>
                <svg class="w-3 h-3 text-gray-300" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <% } %>
              <span class="text-xs text-gray-500 ml-1 font-medium"><%= item.rating.toFixed(1) %></span>
            </div>
            <div class="flex items-center justify-between mt-3">
                <div>
                  <span class="font-bold text-gray-800">₹<%= item.price %></span>
                  <span class="text-xs text-gray-400 line-through ml-1">₹<%= originalPrice %></span>
                </div>
                <button
                  data-items="<%=JSON.stringify(item)%>"
                  class="add-to-cart py-1.5 px-4 rounded-full font-bold text-sm"
                >
                  + Add
                </button>
              </div>
            </div>
          </div>
          <% }) %>
        </div>
        <% } %>
      </div>
    </section>

    <!-- Why FeastFly strip -->
    <section class="bg-orange-50 py-10 px-4 md:px-10">
      <div class="container mx-auto">
        <h2 class="text-xl font-bold text-gray-800 mb-6 text-center">Why Order with FeastFly?</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 text-center">
          <div class="flex flex-col items-center gap-2">
            <div class="w-14 h-14 rounded-full bg-orange-100 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="font-bold text-gray-700">Fast Delivery</h3>
            <p class="text-sm text-gray-500">Hot food at your door in 30 minutes or less.</p>
          </div>
          <div class="flex flex-col items-center gap-2">
            <div class="w-14 h-14 rounded-full bg-orange-100 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="font-bold text-gray-700">Fresh & Hygienic</h3>
            <p class="text-sm text-gray-500">Prepared fresh with the highest hygiene standards.</p>
          </div>
          <div class="flex flex-col items-center gap-2">
            <div class="w-14 h-14 rounded-full bg-orange-100 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="font-bold text-gray-700">Best Prices</h3>
            <p class="text-sm text-gray-500">Exclusive deals and discounts every single day.</p>
          </div>
        </div>
      </div>
    </section>

    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="/app.js"></script>
    <%- include('./partials/footer.ejs') %>
  </body>
</html>
