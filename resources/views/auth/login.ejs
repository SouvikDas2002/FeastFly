<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FeastFly | Login</title>
    <meta
      name="description"
      content="Log in to your FeastFly account to track orders and manage your cart."
    />
    <meta name="theme-color" content="#FE5F1E" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@100;300;400;500;600;700&family=Lato:ital,wght@0,400;0,700;1,400;1,900&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/tailwindcss/2.2.19/tailwind.min.css"
      integrity="sha512-wnea99uKIC3TJF7v4eKk4Y+lMz2Mklv18+r4na2Gn1abDRPPOeef95xTzdwGD9e6zXJBteMIhZ1+68QC5byJZw=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <link rel="stylesheet" href="/css/app.css" />
  </head>
  <body class="bg-gray-50">
    <div class="min-h-screen flex">
      <!-- Left panel — image + branding (desktop only) -->
      <div class="hidden lg:flex lg:w-1/2 relative overflow-hidden">
        <img
          src="/img/hero-img.jpg"
          alt="FeastFly"
          class="absolute inset-0 w-full h-full object-cover"
        />
        <div
          class="absolute inset-0"
          style="
            background: linear-gradient(
              135deg,
              rgba(0, 0, 0, 0.72) 0%,
              rgba(254, 95, 30, 0.55) 100%
            );
          "
        ></div>
        <div class="relative z-10 flex flex-col justify-between p-12 w-full">
          <!-- Logo -->
          <a href="/">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 155 40" height="40">
              <path
                d="M17,2 C13,8 9,16 13,23 C14,27 17,29 17,35 C21,30 23,25 19,19 C21,23 25,24 23,30 C27,24 27,14 21,9 C21,15 19,19 17,19 C15,13 17,8 17,2 Z"
                fill="#FE5F1E"
              />
              <text x="34" y="29" font-family="Lato,sans-serif" font-weight="900" font-size="25">
                <tspan fill="#ffffff">Feast</tspan>
                <tspan fill="#FE5F1E">Fly</tspan>
              </text>
            </svg>
          </a>
          <!-- Tagline -->
          <div>
            <h2 class="text-white text-3xl font-bold leading-snug mb-3">
              Fresh food,<br />delivered fast.
            </h2>
            <p class="text-gray-300 text-sm leading-relaxed">
              Order from our menu and get your favourite meals delivered hot to your doorstep.
            </p>
          </div>
        </div>
      </div>

      <!-- Right panel — form -->
      <div class="w-full lg:w-1/2 flex items-center justify-center px-6 py-12">
        <div class="w-full max-w-md">
          <!-- Mobile logo -->
          <div class="lg:hidden mb-8">
            <a href="/">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 155 40" height="36">
                <path
                  d="M17,2 C13,8 9,16 13,23 C14,27 17,29 17,35 C21,30 23,25 19,19 C21,23 25,24 23,30 C27,24 27,14 21,9 C21,15 19,19 17,19 C15,13 17,8 17,2 Z"
                  fill="#FE5F1E"
                />
                <text x="34" y="29" font-family="Lato,sans-serif" font-weight="900" font-size="25">
                  <tspan fill="#1a1818">Feast</tspan>
                  <tspan fill="#FE5F1E">Fly</tspan>
                </text>
              </svg>
            </a>
          </div>

          <h1 class="text-2xl font-bold text-gray-800 mb-1">Welcome back</h1>
          <p class="text-gray-500 text-sm mb-8">Sign in to continue ordering</p>

          <% if(messages.err){ %>
          <div
            class="mb-4 px-4 py-3 bg-red-50 border border-red-200 rounded-lg text-red-600 text-sm"
          >
            <%= messages.err %>
          </div>
          <% } %>

          <form action="/login" method="post" class="space-y-4">
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1"
                >Email address</label
              >
              <input
                type="email"
                name="email"
                id="email"
                placeholder="you@example.com"
                required
                class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm text-gray-900 bg-white focus:outline-none focus:border-orange-400 focus:ring-1 focus:ring-orange-400 transition-colors"
              />
            </div>

            <div>
              <label for="password" class="block text-sm font-medium text-gray-700 mb-1"
                >Password</label
              >
              <input
                type="password"
                name="password"
                id="password"
                placeholder="••••••••"
                required
                class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm text-gray-900 bg-white focus:outline-none focus:border-orange-400 focus:ring-1 focus:ring-orange-400 transition-colors"
              />
            </div>

            <button
              type="submit"
              class="btn-primary w-full py-2.5 rounded-lg text-white font-semibold text-sm tracking-wide"
            >
              Sign in
            </button>
          </form>

          <div class="flex items-center gap-3 my-5">
            <div class="flex-1 h-px bg-gray-200"></div>
            <span class="text-xs text-gray-400 font-medium">OR</span>
            <div class="flex-1 h-px bg-gray-200"></div>
          </div>

          <a
            href="/auth/google"
            class="w-full flex items-center justify-center gap-3 border border-gray-300 bg-white rounded-lg px-4 py-2.5 text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors shadow-sm"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 48 48"
              class="w-5 h-5 flex-shrink-0"
            >
              <path
                fill="#EA4335"
                d="M24 9.5c3.5 0 6.6 1.2 9.1 3.2l6.8-6.8C35.8 2.5 30.2 0 24 0 14.6 0 6.6 5.4 2.6 13.3l7.9 6.1C12.4 13 17.7 9.5 24 9.5z"
              />
              <path
                fill="#4285F4"
                d="M46.5 24.5c0-1.6-.1-3.1-.4-4.5H24v8.5h12.7c-.6 3-2.3 5.5-4.8 7.2l7.5 5.8c4.4-4.1 6.9-10.1 7.1-17z"
              />
              <path
                fill="#FBBC05"
                d="M10.5 28.6A14.5 14.5 0 0 1 9.5 24c0-1.6.3-3.1.8-4.6l-7.9-6.1A23.9 23.9 0 0 0 0 24c0 3.9.9 7.5 2.6 10.7l7.9-6.1z"
              />
              <path
                fill="#34A853"
                d="M24 48c6.2 0 11.4-2 15.2-5.5l-7.5-5.8c-2 1.4-4.7 2.2-7.7 2.2-6.3 0-11.6-4.2-13.5-9.9l-7.9 6.1C6.6 42.6 14.6 48 24 48z"
              />
            </svg>
            Continue with Google
          </a>

          <p class="text-sm text-gray-500 text-center mt-6">
            Don't have an account?
            <a href="/register" class="font-semibold hover:underline" style="color: #fe5f1e"
              >Sign up</a
            >
          </p>
        </div>
      </div>
    </div>
  </body>
</html>
