<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FeastFly | My Profile</title>
    <meta name="description" content="Manage your FeastFly profile and saved delivery addresses." />
    <meta name="theme-color" content="#FE5F1E" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@100;300;400;500;600;700&family=Lato:ital,wght@0,400;0,700;1,400;1,900&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/tailwindcss/2.2.19/tailwind.min.css"
      integrity="sha512-wnea99uKIC3TJF7v4eKk4Y+lMz2Mklv18+r4na2Gn1abDRPPOeef95xTzdwGD9e6zXJBteMIhZ1+68QC5byJZw=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <link rel="stylesheet" href="/css/app.css" />
    <style>
      .faq-answer { display: none; }
      .faq-item.open .faq-answer { display: block; }
      .faq-item.open .faq-chevron { transform: rotate(180deg); }
      .faq-chevron { transition: transform 0.2s; }
    </style>
  </head>
  <body>
    <%- include("../layout.ejs") %>

    <section class="py-10 pb-20">
      <div class="container mx-auto max-w-lg px-4">

        <% if(messages.err){ %>
        <div class="bg-red-100 text-red-700 rounded-lg p-3 mb-4"><%= messages.err %></div>
        <% } %> <% if(messages.success){ %>
        <div class="bg-green-100 text-green-700 rounded-lg p-3 mb-4"><%= messages.success %></div>
        <% } %>

        <!-- Account info -->
        <div class="flex items-center gap-4 mb-8 pb-6 border-b border-gray-200">
          <div class="w-14 h-14 rounded-full bg-orange-100 flex items-center justify-center flex-shrink-0">
            <span class="text-orange-500 text-2xl font-bold"><%= profileUser.username.charAt(0).toUpperCase() %></span>
          </div>
          <div>
            <h2 class="text-xl font-bold leading-tight"><%= profileUser.username %></h2>
            <p class="text-gray-500 text-sm"><%= profileUser.email %></p>
          </div>
        </div>

        <!-- ── 1. Credits ─────────────────────────────── -->
        <div class="mb-8">
          <h3 class="text-lg font-bold mb-3">My Credits</h3>
          <div class="rounded-2xl p-5 text-white flex items-center justify-between" style="background:linear-gradient(135deg,#FE5F1E,#e53e3e)">
            <div>
              <p class="text-sm opacity-80 mb-1">Available Balance</p>
              <p class="text-4xl font-extrabold">₹<%= profileUser.credits || 0 %></p>
              <p class="text-xs opacity-70 mt-1">Redeemable on your next order</p>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
            </svg>
          </div>
        </div>

        <!-- ── 2. Refer & Earn ─────────────────────────── -->
        <div class="mb-8 pt-6 border-t border-gray-200">
          <div class="flex items-center gap-2 mb-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <h3 class="text-lg font-bold">Refer & Earn</h3>
          </div>
          <p class="text-sm text-gray-500 mb-4">Invite friends to FeastFly. You both get <span class="font-semibold text-orange-500">₹50 credits</span> when they place their first order.</p>

          <div class="bg-orange-50 border border-orange-200 rounded-2xl p-4 flex items-center justify-between gap-3 mb-3">
            <div>
              <p class="text-xs text-gray-400 mb-1">Your referral code</p>
              <p id="ref-code" class="text-2xl font-extrabold text-orange-500 tracking-widest"><%= profileUser.referralCode %></p>
            </div>
            <button
              onclick="copyReferralCode()"
              id="copy-btn"
              class="btn-primary px-4 py-2 rounded-full text-white text-sm font-bold flex-shrink-0"
            >
              Copy
            </button>
          </div>

          <a
            href="https://wa.me/?text=Hey!%20Use%20my%20code%20<%= profileUser.referralCode %>%20on%20FeastFly%20and%20we%20both%20get%20%E2%82%B950%20credits!%20Order%20now%20at%20feastfly.com"
            target="_blank"
            class="flex items-center gap-2 border border-gray-200 rounded-xl px-4 py-3 text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors w-full"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-500" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Share via WhatsApp
          </a>
        </div>

        <!-- ── 3. Saved Addresses ───────────────────────── -->
        <div class="mb-8 pt-6 border-t border-gray-200">
          <h3 class="text-lg font-bold mb-4">Saved Addresses</h3>

          <% if(profileUser.addresses && profileUser.addresses.length > 0){ %>
          <ul class="space-y-3 mb-5">
            <% profileUser.addresses.forEach(a => { %>
            <li class="flex items-start justify-between bg-gray-50 rounded-xl p-4">
              <div class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-orange-400 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <div>
                  <p class="font-semibold text-sm"><%= a.label %></p>
                  <p class="text-gray-600 text-sm mt-0.5"><%= a.address %></p>
                </div>
              </div>
              <form action="/customer/addresses/delete" method="post" class="ml-4 flex-shrink-0">
                <input type="hidden" name="addressId" value="<%= a._id %>" />
                <button type="submit" class="text-gray-400 hover:text-red-500 text-xs font-medium transition-colors">Remove</button>
              </form>
            </li>
            <% }) %>
          </ul>
          <% } else { %>
          <p class="text-gray-400 text-sm mb-5">No saved addresses yet.</p>
          <% } %>

          <div class="bg-gray-50 rounded-xl p-5">
            <h4 class="font-bold mb-4 text-sm">Add New Address</h4>
            <form action="/customer/addresses" method="post" class="space-y-3">
              <input type="text" name="label" placeholder="Label (e.g. Home, Work)" required
                class="border border-gray-300 p-2 w-full rounded-full text-sm focus:outline-none focus:border-orange-400" />
              <input type="text" name="address" placeholder="Full delivery address" required
                class="border border-gray-300 p-2 w-full rounded-full text-sm focus:outline-none focus:border-orange-400" />
              <button type="submit" class="btn-primary px-6 py-2 rounded-full text-white font-bold text-sm">Save Address</button>
            </form>
          </div>
        </div>

        <!-- ── 4. Saved Payment Methods ───────────────────── -->
        <div class="mb-8 pt-6 border-t border-gray-200">
          <div class="flex items-center gap-2 mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
            </svg>
            <h3 class="text-lg font-bold">Saved Payment Methods</h3>
          </div>

          <div class="bg-gray-50 rounded-2xl p-6 text-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-gray-300 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
            </svg>
            <p class="text-gray-500 text-sm font-medium">No saved payment methods</p>
            <p class="text-gray-400 text-xs mt-1">Cards and UPI are saved securely during checkout</p>
            <div class="flex items-center justify-center gap-2 mt-4 opacity-50">
              <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/5/5e/Visa_Inc._logo.svg/200px-Visa_Inc._logo.svg.png" alt="Visa" class="h-4 object-contain" />
              <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/2/2a/Mastercard-logo.svg/200px-Mastercard-logo.svg.png" alt="Mastercard" class="h-5 object-contain" />
              <span class="text-xs font-bold text-gray-600 border border-gray-300 px-2 py-0.5 rounded">UPI</span>
            </div>
          </div>
        </div>

        <!-- ── 5. Help & Support ───────────────────────────── -->
        <div class="mb-8 pt-6 border-t border-gray-200">
          <div class="flex items-center gap-2 mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
            <h3 class="text-lg font-bold">Help & Support</h3>
          </div>

          <!-- Contact options -->
          <div class="grid grid-cols-2 gap-3 mb-5">
            <a href="mailto:support@feastfly.com" class="flex flex-col items-center gap-2 bg-gray-50 rounded-xl p-4 hover:bg-orange-50 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <span class="text-xs font-semibold text-gray-700">Email Us</span>
              <span class="text-xs text-gray-400">support@feastfly.com</span>
            </a>
            <a href="tel:+919999999999" class="flex flex-col items-center gap-2 bg-gray-50 rounded-xl p-4 hover:bg-orange-50 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <span class="text-xs font-semibold text-gray-700">Call Us</span>
              <span class="text-xs text-gray-400">+91 99999 99999</span>
            </a>
          </div>

          <!-- FAQ Accordion -->
          <h4 class="text-sm font-bold text-gray-700 mb-3">Frequently Asked Questions</h4>
          <div class="space-y-2" id="faq-list">

            <div class="faq-item border border-gray-200 rounded-xl overflow-hidden">
              <button class="faq-toggle w-full flex items-center justify-between px-4 py-3 text-sm font-medium text-gray-700 text-left">
                How do I track my order?
                <svg class="faq-chevron h-4 w-4 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="faq-answer px-4 pb-3 text-sm text-gray-500">
                Go to <strong>My Orders</strong> from the navigation. Each order shows a live status — from placed → preparing → out for delivery → delivered.
              </div>
            </div>

            <div class="faq-item border border-gray-200 rounded-xl overflow-hidden">
              <button class="faq-toggle w-full flex items-center justify-between px-4 py-3 text-sm font-medium text-gray-700 text-left">
                Can I cancel my order?
                <svg class="faq-chevron h-4 w-4 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="faq-answer px-4 pb-3 text-sm text-gray-500">
                Orders can be cancelled within 2 minutes of placement. After that, please contact our support team directly.
              </div>
            </div>

            <div class="faq-item border border-gray-200 rounded-xl overflow-hidden">
              <button class="faq-toggle w-full flex items-center justify-between px-4 py-3 text-sm font-medium text-gray-700 text-left">
                How do credits work?
                <svg class="faq-chevron h-4 w-4 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="faq-answer px-4 pb-3 text-sm text-gray-500">
                Credits are earned through referrals and promotions. They are automatically applied as a discount on your next order at checkout.
              </div>
            </div>

            <div class="faq-item border border-gray-200 rounded-xl overflow-hidden">
              <button class="faq-toggle w-full flex items-center justify-between px-4 py-3 text-sm font-medium text-gray-700 text-left">
                What if my payment failed but amount was deducted?
                <svg class="faq-chevron h-4 w-4 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="faq-answer px-4 pb-3 text-sm text-gray-500">
                Such amounts are auto-refunded by Razorpay within 5–7 business days. If not received, email us with your transaction ID.
              </div>
            </div>

            <div class="faq-item border border-gray-200 rounded-xl overflow-hidden">
              <button class="faq-toggle w-full flex items-center justify-between px-4 py-3 text-sm font-medium text-gray-700 text-left">
                How do I change my delivery address?
                <svg class="faq-chevron h-4 w-4 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="faq-answer px-4 pb-3 text-sm text-gray-500">
                You can save multiple addresses here on your profile and select the right one at checkout each time.
              </div>
            </div>

          </div>
        </div>

      </div>
    </section>

    <script>
      // FAQ accordion
      document.querySelectorAll('.faq-toggle').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var item = btn.closest('.faq-item');
          var isOpen = item.classList.contains('open');
          document.querySelectorAll('.faq-item').forEach(function (i) { i.classList.remove('open'); });
          if (!isOpen) item.classList.add('open');
        });
      });

      // Copy referral code
      function copyReferralCode() {
        var code = document.getElementById('ref-code').innerText;
        if (navigator.clipboard) {
          navigator.clipboard.writeText(code).then(function () {
            var btn = document.getElementById('copy-btn');
            btn.innerText = 'Copied!';
            setTimeout(function () { btn.innerText = 'Copy'; }, 2000);
          });
        } else {
          var ta = document.createElement('textarea');
          ta.value = code;
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
          var btn = document.getElementById('copy-btn');
          btn.innerText = 'Copied!';
          setTimeout(function () { btn.innerText = 'Copy'; }, 2000);
        }
      }
    </script>

    <%- include('../partials/footer.ejs') %>
  </body>
</html>
