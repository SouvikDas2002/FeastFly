<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FeastFly | My Orders</title>
    <meta name="description" content="View your current and past food orders on FeastFly." />
    <meta name="theme-color" content="#FE5F1E" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@100;300;400;500;600;700&family=Lato:ital,wght@0,400;0,700;1,400;1,900&family=Lora:ital,wght@1,400;1,500;1,600&family=Urbanist:wght@100&family=Varela&family=Varela+Round&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/tailwindcss/2.2.19/tailwind.min.css"
      integrity="sha512-wnea99uKIC3TJF7v4eKk4Y+lMz2Mklv18+r4na2Gn1abDRPPOeef95xTzdwGD9e6zXJBteMIhZ1+68QC5byJZw=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <link rel="stylesheet" href="/css/app.css" />
  </head>
  <body>
    <%- include('../layout.ejs') %>
    <section class="orders light-section mt-6 px-4 md:px-10" style="min-height: 70vh">
      <div class="container mx-auto pt-8">
        <h1 class="font-bold text-lg mb-4">All orders</h1>
        <% if(messages.success) { %>
        <div
          id="success-alert"
          class="flex items-center bg-green-500 text-white text-sm font-bold px-4 py-3"
          role="alert"
        >
          <svg
            class="fill-current w-4 h-4 mr-2"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
          >
            <path
              d="M12.432 0c1.34 0 2.01.912 2.01 1.957 0 1.305-1.164 2.512-2.679 2.512-1.269 0-2.009-.75-1.974-1.99C9.789 1.436 10.67 0 12.432 0zM8.309 20c-1.058 0-1.833-.652-1.093-3.524l1.214-5.092c.211-.814.246-1.141 0-1.141-.317 0-1.689.562-2.502 1.117l-.528-.88c2.572-2.186 5.531-3.467 6.801-3.467 1.057 0 1.233 1.273.705 3.23l-1.391 5.352c-.246.945-.141 1.271.106 1.271.317 0 1.357-.392 2.379-1.207l.6.814C12.098 19.02 9.365 20 8.309 20z"
            />
          </svg>
          <p><%= messages.success %></p>
        </div>
        <% } %>
        <div class="overflow-x-auto">
          <table class="w-full table-auto bg-white min-w-max">
            <thead>
              <tr>
                <th class="px-4 py-2 text-left">Orders</th>
                <th class="px-4 py-2 text-left">Phone</th>
                <th class="px-4 py-2 text-left">Address</th>
                <th class="px-4 py-2 text-left">Time</th>
                <th class="px-4 py-2 text-left">Payment</th>
                <th class="px-4 py-2 text-left">Status</th>
              </tr>
            </thead>
            <tbody>
              <% if(orders.length) { %> <% orders.forEach((order) => { %> <% const statusMap = {
              order_placed: { label: 'Order Placed', color: 'bg-blue-100 text-blue-800' },
              confirmed: { label: 'Confirmed', color: 'bg-yellow-100 text-yellow-800' }, prepared: {
              label: 'Preparing', color: 'bg-orange-100 text-orange-800' }, delivered: { label: 'Out
              for Delivery', color: 'bg-purple-100 text-purple-800' }, completed: { label:
              'Completed', color: 'bg-green-100 text-green-800' }, }; const s =
              statusMap[order.status] || { label: order.status, color: 'bg-gray-100 text-gray-800'
              }; %>
              <tr>
                <td class="border px-4 py-2">
                  <a class="link" href="/customer/order/<%= order._id %>"><%= order._id %></a>
                </td>
                <td class="border px-4 py-2"><%= order.phone %></td>
                <td class="border px-4 py-2"><%= order.address %></td>
                <td class="border px-4 py-2"><%= moment(order.createdAt).format('hh:mm A') %></td>
                <td class="border px-4 py-2"><%= order.paymentType %></td>
                <td class="border px-4 py-2">
                  <span
                    id="status-<%= order._id %>"
                    class="px-2 py-1 rounded-full text-xs font-semibold <%= s.color %>"
                    ><%= s.label %></span
                  >
                </td>
              </tr>
              <% }) %> <% } else { %>
              <tr>
                <td class="p-4"><span>No orders found!</span></td>
              </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </section>
    <input
      type="hidden"
      id="orderIdsData"
      value="<%= JSON.stringify(orders.map(o => o._id.toString())) %>"
    />
    <script src="/socket.io/socket.io.js"></script>
    <script>
      const statusMap = {
        order_placed: { label: 'Order Placed', color: 'bg-blue-100 text-blue-800' },
        confirmed: { label: 'Confirmed', color: 'bg-yellow-100 text-yellow-800' },
        prepared: { label: 'Preparing', color: 'bg-orange-100 text-orange-800' },
        delivered: { label: 'Out for Delivery', color: 'bg-purple-100 text-purple-800' },
        completed: { label: 'Completed', color: 'bg-green-100 text-green-800' },
      };

      const socket = io();
      const orderIds = JSON.parse(document.getElementById('orderIdsData').value);
      orderIds.forEach((id) => socket.emit('join', 'order_' + id));

      socket.on('orderUpdated', (data) => {
        const badge = document.getElementById('status-' + data.id);
        if (!badge) return;
        const s = statusMap[data.status] || {
          label: data.status,
          color: 'bg-gray-100 text-gray-800',
        };
        badge.className = 'px-2 py-1 rounded-full text-xs font-semibold ' + s.color;
        badge.textContent = s.label;
      });
    </script>
    <%- include('../partials/footer.ejs') %>
  </body>
</html>
