<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FeastFly | Your Cart</title>
    <meta
      name="description"
      content="Review the items in your cart and place your order with FeastFly."
    />
    <meta name="theme-color" content="#FE5F1E" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@100;300;400;500;600;700&family=Lato:ital,wght@0,400;0,700;1,400;1,900&family=Lora:ital,wght@1,400;1,500;1,600&family=Urbanist:wght@100&family=Varela&family=Varela+Round&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/tailwindcss/2.2.19/tailwind.min.css"
      integrity="sha512-wnea99uKIC3TJF7v4eKk4Y+lMz2Mklv18+r4na2Gn1abDRPPOeef95xTzdwGD9e6zXJBteMIhZ1+68QC5byJZw=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <link rel="stylesheet" href="/css/app.css" />
    <style>
      .qty-btn {
        width: 2rem;
        height: 2rem;
        border-radius: 50%;
        border: 1.5px solid #ccc;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.2s;
      }
      .qty-btn:hover {
        background: #fe5f1e;
        color: #fff;
        border-color: #fe5f1e;
      }
      .remove-btn {
        cursor: pointer;
        color: #ccc;
        transition: color 0.2s;
      }
      .remove-btn:hover {
        color: #e53e3e;
      }
      .payment-tab {
        padding: 0.5rem 1.25rem;
        border-radius: 9999px;
        border: 1.5px solid #ccc;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
      }
      .payment-tab.active {
        background: #fe5f1e;
        color: #fff;
        border-color: #fe5f1e;
      }
    </style>
  </head>
  <body>
    <%- include("../layout.ejs") %>

    <section class="cart py-16">
      <% if(!session.cart){ %>
      <div class="empty-cart py-16">
        <div class="container mx-auto text-center">
          <h1 class="text-3xl font-bold mb-2">Cart Empty 🫤</h1>
          <p class="text-gray-500 text-lg mb-12">
            You probably haven't ordered any food yet.<br />
            To Order, go to main page.
          </p>
          <img class="w-2/5 mx-auto" src="/img/empty-cart.png" alt="empty-cart" />
          <a
            href="/"
            class="inline-block px-6 py-2 rounded-full btn-primary text-white font-bold mt-12"
            >Go Back</a
          >
        </div>
      </div>
      <% } else { %>
      <div class="order container mx-auto w-full xl:w-1/2">
        <div class="flex items-center border-b border-gray-300 pb-4">
          <h1 class="font-bold text-2xl">Order Summary</h1>
        </div>

        <!-- Item list -->
        <div class="pizza-list" id="item-list">
          <% for(let food of Object.values(session.cart.items)){ %>
          <div class="cart-item flex items-center my-6 gap-4" data-id="<%= food.item._id %>">
            <img class="w-20 flex-shrink-0" src="/img/<%= food.item.image %>" alt="" />
            <div class="flex-1">
              <p class="font-semibold"><%= food.item.name %></p>
              <span class="text-xs text-gray-500 uppercase"><%= food.item.size %></span>
            </div>
            <!-- Qty controls -->
            <div class="flex items-center gap-2">
              <button
                class="qty-btn decrement-btn"
                data-id="<%= food.item._id %>"
                data-price="<%= food.item.price %>"
              >
                −
              </button>
              <span class="qty-count w-6 text-center font-bold"><%= food.qty %></span>
              <button
                class="qty-btn increment-btn"
                data-item="<%= JSON.stringify(food.item) %>"
                data-price="<%= food.item.price %>"
              >
                +
              </button>
            </div>
            <span class="font-bold text-lg item-subtotal w-20 text-right"
              >₹<%= food.item.price * food.qty %></span
            >
            <button class="remove-btn text-xl" data-id="<%= food.item._id %>">🗑</button>
          </div>
          <% } %>
        </div>

        <hr />

        <!-- Coupon -->
        <% if(user){ %>
        <div class="mt-4 mb-1">
          <!-- Input row (hidden when a coupon is already applied) -->
          <div id="coupon-input-row" class="flex gap-2 <%= session.cart.coupon ? 'hidden' : '' %>">
            <input
              id="coupon-input"
              type="text"
              placeholder="Have a coupon? Enter code"
              class="border border-gray-300 rounded-full px-4 py-2 text-sm flex-1 focus:outline-none focus:border-orange-400"
              style="text-transform:uppercase"
            />
            <button id="apply-coupon-btn" class="btn-primary px-5 py-2 rounded-full text-white text-sm font-bold whitespace-nowrap">
              Apply
            </button>
          </div>
          <p id="coupon-msg" class="text-xs mt-1.5 hidden"></p>

          <!-- Applied badge (hidden when no coupon) -->
          <div id="coupon-applied-row" class="<%= session.cart.coupon ? '' : 'hidden' %> flex items-center justify-between bg-green-50 border border-green-200 rounded-2xl px-4 py-3">
            <div>
              <span class="text-green-700 font-bold text-sm">
                🏷️ <span id="coupon-code-display"><%= session.cart.coupon ? session.cart.coupon.code : '' %></span> applied
              </span>
              <span class="text-green-600 text-sm ml-2 font-semibold">
                −₹<span id="coupon-discount-display"><%= session.cart.coupon ? session.cart.coupon.discount : 0 %></span>
              </span>
            </div>
            <button id="remove-coupon-btn" class="text-gray-400 hover:text-red-500 text-xs font-semibold ml-4 transition-colors">
              ✕ Remove
            </button>
          </div>
        </div>
        <% } %>

        <!-- Total -->
        <div class="text-right py-4">
          <div id="subtotal-line" class="text-gray-500 text-sm mb-1 <%= session.cart.coupon ? '' : 'hidden' %>">
            Subtotal: ₹<span id="subtotal-amount"><%= session.cart.totalPrice %></span>
          </div>
          <div id="discount-line" class="text-green-600 font-semibold text-sm mb-1 <%= session.cart.coupon ? '' : 'hidden' %>">
            Discount: −₹<span id="discount-amount"><%= session.cart.coupon ? session.cart.coupon.discount : 0 %></span>
          </div>
          <span class="text-lg font-bold">Total: </span>
          <span id="cart-total" class="text-2xl font-bold ml-2">
            ₹<%= session.cart.coupon ? session.cart.coupon.finalTotal : session.cart.totalPrice %>
          </span>
        </div>

        <% if(user){ %>
        <!-- Checkout form -->
        <div class="checkout mt-4 space-y-4">
          <!-- Saved addresses -->
          <% if(typeof addresses !== 'undefined' && addresses.length > 0){ %>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Saved Addresses</label>
            <select
              id="saved-address-select"
              class="border border-gray-300 rounded-full p-2 w-full"
            >
              <option value="">— Type a new address —</option>
              <% addresses.forEach(a => { %>
              <option value="<%= a.address %>"><%= a.label %> — <%= a.address %></option>
              <% }) %>
            </select>
          </div>
          <% } %>

          <input
            id="phone-input"
            class="border border-gray-400 p-2 w-full rounded-full"
            type="text"
            placeholder="Phone Number"
            required
          />
          <input
            id="address-input"
            class="border border-gray-400 p-2 w-full rounded-full"
            type="text"
            placeholder="Delivery Address"
            required
          />

          <!-- Payment method tabs -->
          <div class="flex gap-3 pt-2">
            <button id="tab-cod" class="payment-tab active" type="button">Cash on Delivery</button>
            <button id="tab-online" class="payment-tab" type="button">Pay Online</button>
          </div>

          <!-- Hidden COD form -->
          <form id="cod-form" action="/orders" method="post" class="hidden">
            <input type="hidden" name="number" id="cod-number" />
            <input type="hidden" name="address" id="cod-address" />
          </form>

          <button
            id="place-order-btn"
            class="btn-primary px-6 py-2 rounded-full text-white font-bold mt-2"
          >
            Place Order
          </button>

          <div class="mt-2">
            <a href="/customer/profile" class="text-sm text-gray-500 underline"
              >Manage saved addresses</a
            >
          </div>
        </div>
        <% } else { %>
        <a
          href="/login"
          class="inline-block cursor-pointer btn-primary px-6 py-2 rounded-full text-white font-bold mt-5"
          >Login to Continue</a
        >
        <% } %>
      </div>
      <% } %>
    </section>

    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script>
      const cartTotal         = document.getElementById('cart-total');
      const cartCounter       = document.getElementById('cartCounter');
      const mobileCartCounter = document.getElementById('mobileCartCounter');

      function syncCartCounters(qty) {
        if (cartCounter) cartCounter.innerText = qty;
        if (mobileCartCounter) {
          mobileCartCounter.innerText = qty > 0 ? qty : '';
          mobileCartCounter.style.display = qty > 0 ? 'flex' : 'none';
        }
      }
      const subtotalLine = document.getElementById('subtotal-line');
      const discountLine = document.getElementById('discount-line');
      const subtotalAmountEl  = document.getElementById('subtotal-amount');
      const discountAmountEl  = document.getElementById('discount-amount');
      const couponInputRow    = document.getElementById('coupon-input-row');
      const couponAppliedRow  = document.getElementById('coupon-applied-row');
      const couponCodeDisplay = document.getElementById('coupon-code-display');
      const couponDiscDisplay = document.getElementById('coupon-discount-display');

      var appliedDiscount = <%= session.cart && session.cart.coupon ? session.cart.coupon.discount : 0 %>;

      function recalcTotal() {
        let subtotal = 0;
        document.querySelectorAll('.item-subtotal').forEach((el) => {
          subtotal += parseInt(el.innerText.replace('₹', '')) || 0;
        });
        if (appliedDiscount > 0) {
          const eff   = Math.min(appliedDiscount, subtotal);
          const final = subtotal - eff;
          if (subtotalLine)    subtotalLine.classList.remove('hidden');
          if (subtotalAmountEl) subtotalAmountEl.innerText = subtotal;
          if (discountLine)    discountLine.classList.remove('hidden');
          if (discountAmountEl) discountAmountEl.innerText = eff;
          if (cartTotal)       cartTotal.innerText = '₹' + final;
        } else {
          if (subtotalLine) subtotalLine.classList.add('hidden');
          if (discountLine) discountLine.classList.add('hidden');
          if (cartTotal)    cartTotal.innerText = '₹' + subtotal;
        }
      }

      async function clearCouponUI() {
        if (appliedDiscount === 0) return;
        appliedDiscount = 0;
        try { await axios.post('/remove-coupon'); } catch (_) {}
        if (couponAppliedRow) couponAppliedRow.classList.add('hidden');
        if (couponInputRow)   couponInputRow.classList.remove('hidden');
        recalcTotal();
      }

      // Qty increment
      document.querySelectorAll('.increment-btn').forEach((btn) => {
        btn.addEventListener('click', async () => {
          await clearCouponUI();
          const itemData = JSON.parse(btn.dataset.item);
          itemData.type = 'add';
          const res = await axios.post('/update-cart', itemData);
          const row = btn.closest('.cart-item');
          const qtyEl = row.querySelector('.qty-count');
          const subtotalEl = row.querySelector('.item-subtotal');
          const price = parseInt(btn.dataset.price);
          const newQty = parseInt(qtyEl.innerText) + 1;
          qtyEl.innerText = newQty;
          subtotalEl.innerText = '₹' + price * newQty;
          syncCartCounters(res.data.totalQty);
          recalcTotal();
        });
      });

      // Qty decrement
      document.querySelectorAll('.decrement-btn').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const id = btn.dataset.id;
          const price = parseInt(btn.dataset.price);
          const row = btn.closest('.cart-item');
          const qtyEl = row.querySelector('.qty-count');
          const currentQty = parseInt(qtyEl.innerText);
          if (currentQty <= 1) {
            await removeItem(id, row);
            return;
          }
          await clearCouponUI();
          const res = await axios.post('/update-cart', { _id: id, price, type: 'decrement' });
          const newQty = currentQty - 1;
          qtyEl.innerText = newQty;
          row.querySelector('.item-subtotal').innerText = '₹' + price * newQty;
          syncCartCounters(res.data.totalQty);
          recalcTotal();
        });
      });

      // Remove item
      document.querySelectorAll('.remove-btn').forEach((btn) => {
        btn.addEventListener('click', async () => {
          await removeItem(btn.dataset.id, btn.closest('.cart-item'));
        });
      });

      async function removeItem(id, row) {
        await clearCouponUI();
        const res = await axios.post('/remove-from-cart', { _id: id });
        row.remove();
        if (cartCounter) cartCounter.innerText = res.data.totalQty;
        recalcTotal();
        if (res.data.totalQty === 0) location.reload();
      }

      // Apply coupon
      const applyCouponBtn = document.getElementById('apply-coupon-btn');
      const couponInput    = document.getElementById('coupon-input');
      const couponMsg      = document.getElementById('coupon-msg');

      if (applyCouponBtn && couponInput) {
        applyCouponBtn.addEventListener('click', async () => {
          const code = couponInput.value.trim();
          if (!code) return;
          applyCouponBtn.disabled = true;
          applyCouponBtn.innerText = '...';
          couponMsg.classList.add('hidden');
          try {
            const { data } = await axios.post('/apply-coupon', { code });
            if (data.error) {
              couponMsg.textContent = data.error;
              couponMsg.className = 'text-xs mt-1.5 text-red-500';
              couponMsg.classList.remove('hidden');
            } else {
              appliedDiscount = data.discount;
              if (couponCodeDisplay) couponCodeDisplay.innerText = data.code;
              if (couponDiscDisplay) couponDiscDisplay.innerText = data.discount;
              if (couponInputRow)   couponInputRow.classList.add('hidden');
              if (couponAppliedRow) couponAppliedRow.classList.remove('hidden');
              recalcTotal();
            }
          } catch (_) {
            couponMsg.textContent = 'Something went wrong. Please try again.';
            couponMsg.className = 'text-xs mt-1.5 text-red-500';
            couponMsg.classList.remove('hidden');
          }
          applyCouponBtn.disabled = false;
          applyCouponBtn.innerText = 'Apply';
        });

        couponInput.addEventListener('keydown', (e) => {
          if (e.key === 'Enter') applyCouponBtn.click();
        });
      }

      // Remove coupon
      const removeCouponBtn = document.getElementById('remove-coupon-btn');
      if (removeCouponBtn) {
        removeCouponBtn.addEventListener('click', () => clearCouponUI());
      }

      // Saved address selector
      const savedSelect = document.getElementById('saved-address-select');
      const addressInput = document.getElementById('address-input');
      if (savedSelect && addressInput) {
        savedSelect.addEventListener('change', () => {
          if (savedSelect.value) addressInput.value = savedSelect.value;
        });
      }

      // Payment tabs
      const tabCod = document.getElementById('tab-cod');
      const tabOnline = document.getElementById('tab-online');
      let paymentMethod = 'cod';

      if (tabCod && tabOnline) {
        tabCod.addEventListener('click', () => {
          paymentMethod = 'cod';
          tabCod.classList.add('active');
          tabOnline.classList.remove('active');
        });
        tabOnline.addEventListener('click', () => {
          paymentMethod = 'online';
          tabOnline.classList.add('active');
          tabCod.classList.remove('active');
        });
      }

      // Place order
      const placeBtn = document.getElementById('place-order-btn');
      if (placeBtn) {
        placeBtn.addEventListener('click', async () => {
          const phone = document.getElementById('phone-input').value.trim();
          const address = document.getElementById('address-input').value.trim();
          if (!phone || !address) {
            alert('Please enter your phone number and delivery address.');
            return;
          }

          if (paymentMethod === 'cod') {
            document.getElementById('cod-number').value = phone;
            document.getElementById('cod-address').value = address;
            document.getElementById('cod-form').submit();
          } else {
            placeBtn.disabled = true;
            placeBtn.innerText = 'Processing…';
            try {
              const { data } = await axios.post('/payment/create-order');
              const options = {
                key: data.key,
                amount: data.amount,
                currency: data.currency,
                name: 'FeastFly',
                description: 'Food Order Payment',
                order_id: data.razorpayOrderId,
                handler: async (response) => {
                  const verify = await axios.post('/payment/verify', {
                    razorpay_order_id: response.razorpay_order_id,
                    razorpay_payment_id: response.razorpay_payment_id,
                    razorpay_signature: response.razorpay_signature,
                    phone,
                    address,
                  });
                  if (verify.data.success) {
                    window.location.href = '/customer/order/' + verify.data.orderId;
                  }
                },
                prefill: { contact: phone },
                theme: { color: '#FE5F1E' },
                modal: {
                  ondismiss: () => {
                    placeBtn.disabled = false;
                    placeBtn.innerText = 'Place Order';
                  },
                },
              };
              const rzp = new Razorpay(options);
              rzp.open();
            } catch (err) {
              alert('Could not initiate payment. Please try again.');
              placeBtn.disabled = false;
              placeBtn.innerText = 'Place Order';
            }
          }
        });
      }
    </script>
    <%- include('../partials/footer.ejs') %>
  </body>
</html>
