<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FeastFly | Order Details</title>
    <meta name="description" content="Track your FeastFly order in real time." />
    <meta name="theme-color" content="#FE5F1E" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@100;300;400;500;600;700&family=Lato:ital,wght@0,400;0,700;1,400;1,900&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/tailwindcss/2.2.19/tailwind.min.css"
      integrity="sha512-wnea99uKIC3TJF7v4eKk4Y+lMz2Mklv18+r4na2Gn1abDRPPOeef95xTzdwGD9e6zXJBteMIhZ1+68QC5byJZw=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="stylesheet" href="https://maxst.icons8.com/vue-static/landings/line-awesome/line-awesome/1.3.0/css/line-awesome.min.css" />
  </head>
  <body>
    <%- include('../layout.ejs') %>

    <%
      const statusMap = {
        order_placed: { label: 'Order Placed',    color: 'bg-blue-100 text-blue-700'    },
        confirmed:    { label: 'Confirmed',        color: 'bg-yellow-100 text-yellow-700' },
        prepared:     { label: 'Preparing',        color: 'bg-orange-100 text-orange-700' },
        delivered:    { label: 'Out for Delivery', color: 'bg-purple-100 text-purple-700' },
        completed:    { label: 'Delivered',        color: 'bg-green-100 text-green-700'   },
      };
      const s        = statusMap[order.status] || { label: order.status, color: 'bg-gray-100 text-gray-700' };
      const itemList = Object.values(order.items);
      const paid     = order.finalAmount != null ? order.finalAmount : order.totalAmount;
    %>

    <section class="py-8 px-4 md:px-10 pb-24">
      <div class="container mx-auto max-w-2xl">

        <!-- Header -->
        <div class="flex items-center gap-3 mb-6">
          <a href="/customer/order" class="text-gray-400 hover:text-gray-600">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
          </a>
          <div class="flex-1">
            <h1 class="text-lg font-bold leading-tight">Order Details</h1>
            <p class="text-xs text-gray-400 font-mono">#<%= order._id.toString().slice(-8).toUpperCase() %></p>
          </div>
          <span id="live-status" class="px-3 py-1 rounded-full text-xs font-semibold <%= s.color %>"><%= s.label %></span>
        </div>

        <!-- ── Live Status Tracker ──────────────────── -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 mb-4">
          <h2 class="text-sm font-bold text-gray-700 mb-5">Live Tracking</h2>
          <ul>
            <li class="status_line text-sm pb-10" data-status="order_placed"><span>Order Placed</span></li>
            <li class="status_line text-sm pb-10" data-status="confirmed"><span>Order Confirmed</span></li>
            <li class="status_line text-sm pb-10" data-status="prepared"><span>Being Prepared</span></li>
            <li class="status_line text-sm pb-10" data-status="delivered"><span>Out for Delivery</span></li>
            <li class="status_line text-sm"        data-status="completed"><span>Delivered</span></li>
          </ul>
        </div>

        <!-- ── Items Ordered ────────────────────────── -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 mb-4">
          <h2 class="text-sm font-bold text-gray-700 mb-4">Items Ordered</h2>
          <div class="space-y-4">
            <% itemList.forEach((entry) => { %>
            <div class="flex items-center gap-3">
              <img
                src="/img/<%= entry.item.image %>"
                alt="<%= entry.item.name %>"
                class="w-14 h-14 rounded-xl object-cover flex-shrink-0"
              />
              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold truncate"><%= entry.item.name %></p>
                <p class="text-xs text-gray-400"><%= entry.item.size %></p>
              </div>
              <div class="text-right flex-shrink-0">
                <p class="text-sm font-bold">₹<%= entry.item.price * entry.qty %></p>
                <p class="text-xs text-gray-400">× <%= entry.qty %></p>
              </div>
            </div>
            <% }) %>
          </div>

          <!-- Price breakdown -->
          <div class="mt-5 pt-4 border-t border-gray-100 space-y-2 text-sm">
            <div class="flex justify-between text-gray-500">
              <span>Subtotal</span>
              <span>₹<%= order.totalAmount %></span>
            </div>
            <% if(order.discountAmount && order.discountAmount > 0){ %>
            <div class="flex justify-between text-green-600">
              <span>Discount <% if(order.couponCode){ %>(<%= order.couponCode %>)<% } %></span>
              <span>−₹<%= order.discountAmount %></span>
            </div>
            <% } %>
            <div class="flex justify-between font-bold text-base pt-2 border-t border-gray-100">
              <span>Total Paid</span>
              <span class="text-orange-500">₹<%= paid %></span>
            </div>
          </div>
        </div>

        <!-- ── Delivery Info ────────────────────────── -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 mb-4">
          <h2 class="text-sm font-bold text-gray-700 mb-4">Delivery Details</h2>
          <div class="space-y-3 text-sm">
            <div class="flex gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-orange-400 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <div>
                <p class="text-xs text-gray-400 mb-0.5">Delivery Address</p>
                <p class="text-gray-700 font-medium"><%= order.address %></p>
              </div>
            </div>
            <div class="flex gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-orange-400 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              <div>
                <p class="text-xs text-gray-400 mb-0.5">Phone</p>
                <p class="text-gray-700 font-medium"><%= order.phone %></p>
              </div>
            </div>
          </div>
        </div>

        <!-- ── Payment Info ─────────────────────────── -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 mb-4">
          <h2 class="text-sm font-bold text-gray-700 mb-4">Payment Info</h2>
          <div class="space-y-2 text-sm">
            <div class="flex justify-between">
              <span class="text-gray-500">Method</span>
              <span class="font-medium"><%= order.paymentType === 'COD' ? 'Cash on Delivery' : 'Online Payment' %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-500">Status</span>
              <% if(order.paymentStatus === 'paid'){ %>
              <span class="text-green-600 font-semibold">Paid</span>
              <% } else if(order.paymentStatus === 'failed'){ %>
              <span class="text-red-500 font-semibold">Failed</span>
              <% } else { %>
              <span class="text-yellow-600 font-semibold">Pending</span>
              <% } %>
            </div>
            <% if(order.paymentId){ %>
            <div class="flex justify-between">
              <span class="text-gray-500">Transaction ID</span>
              <span class="text-xs font-mono text-gray-600 truncate max-w-[160px]"><%= order.paymentId %></span>
            </div>
            <% } %>
            <div class="flex justify-between">
              <span class="text-gray-500">Ordered on</span>
              <span class="font-medium"><%= moment(order.createdAt).format('DD MMM YYYY, hh:mm A') %></span>
            </div>
          </div>
        </div>

      </div>
    </section>

    <input id="hiddenInput" type="hidden" value="<%= JSON.stringify(order) %>" />
    <script src="/socket.io/socket.io.js"></script>
    <script src="/app.js"></script>
    <script>
      // Keep live status badge in header in sync
      var liveStatusBadge = document.getElementById('live-status');
      var statusMap = {
        order_placed: { label: 'Order Placed',    color: 'bg-blue-100 text-blue-700'    },
        confirmed:    { label: 'Confirmed',        color: 'bg-yellow-100 text-yellow-700' },
        prepared:     { label: 'Preparing',        color: 'bg-orange-100 text-orange-700' },
        delivered:    { label: 'Out for Delivery', color: 'bg-purple-100 text-purple-700' },
        completed:    { label: 'Delivered',        color: 'bg-green-100 text-green-700'   },
      };
      var sock = typeof io !== 'undefined' ? io() : null;
      if (sock) {
        var orderId = JSON.parse(document.getElementById('hiddenInput').value)._id;
        sock.on('orderUpdated', function (data) {
          var s = statusMap[data.status] || { label: data.status, color: 'bg-gray-100 text-gray-700' };
          if (liveStatusBadge) {
            liveStatusBadge.className = 'px-3 py-1 rounded-full text-xs font-semibold ' + s.color;
            liveStatusBadge.textContent = s.label;
          }
        });
      }
    </script>
    <%- include('../partials/footer.ejs') %>
  </body>
</html>
