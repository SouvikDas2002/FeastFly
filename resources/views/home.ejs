<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FeastFly | Order Food Online</title>
    <meta
      name="description"
      content="Order delicious food online and get it delivered fast to your doorstep. Browse our menu and enjoy fresh meals with FeastFly."
    />
    <meta name="theme-color" content="#FE5F1E" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="FeastFly | Order Food Online" />
    <meta
      property="og:description"
      content="Order delicious food online and get it delivered fast to your doorstep. Browse our menu and enjoy fresh meals with FeastFly."
    />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="FeastFly | Order Food Online" />
    <meta
      name="twitter:description"
      content="Order delicious food online and get it delivered fast to your doorstep."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@100;300;400;500;600;700&family=Lato:ital,wght@0,400;0,700;1,400;1,900&family=Lora:ital,wght@1,400;1,500;1,600&family=Urbanist:wght@100&family=Varela&family=Varela+Round&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/tailwindcss/2.2.19/tailwind.min.css"
      integrity="sha512-wnea99uKIC3TJF7v4eKk4Y+lMz2Mklv18+r4na2Gn1abDRPPOeef95xTzdwGD9e6zXJBteMIhZ1+68QC5byJZw=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <link rel="stylesheet" href="/css/app.css" />
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <link
      rel="stylesheet"
      type="text/css"
      href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css"
    />
  </head>
  <body>
    <%- include("layout.ejs") %>

    <section
      class="hero relative overflow-hidden"
      style="min-height: 260px; max-height: 520px; height: 52vw"
    >
      <!-- Carousel slides -->
      <img
        class="hero-slide absolute inset-0 w-full h-full object-cover opacity-100 transition-opacity duration-1000"
        src="/img/hero-img.jpg"
        alt="Food spread"
      />
      <img
        class="hero-slide absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-1000"
        src="/img/hero-img2.png"
        alt="Restaurant food"
      />
      <img
        class="hero-slide absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-1000"
        src="/img/hero-img3.jpg"
        alt="Delicious meal"
      />

      <!-- Dark overlay + text (always on top) -->
      <div class="absolute inset-0 bg-black bg-opacity-50 flex items-center z-10">
        <div class="container mx-auto px-4 md:px-10 text-white text-center md:text-left">
          <h6 class="text-sm md:text-base font-medium">
            <em>Feeling Hungry ! <b>Don't Wait</b></em>
          </h6>
          <h1 class="text-3xl md:text-5xl lg:text-6xl font-bold mt-2">
            <em>Lets Grab Some Food</em>
          </h1>
          <button class="btn-primary px-6 py-2 font-bold rounded-full text-white mt-6">
            Order Now
          </button>
        </div>
      </div>

      <!-- Dot indicators -->
      <div class="absolute bottom-4 left-0 right-0 flex justify-center gap-2 z-10">
        <span
          class="hero-dot w-2.5 h-2.5 rounded-full bg-white cursor-pointer"
          style="opacity: 1"
        ></span>
        <span
          class="hero-dot w-2.5 h-2.5 rounded-full bg-white cursor-pointer"
          style="opacity: 0.4"
        ></span>
        <span
          class="hero-dot w-2.5 h-2.5 rounded-full bg-white cursor-pointer"
          style="opacity: 0.4"
        ></span>
      </div>
    </section>

    <script>
      (function () {
        var slides = document.querySelectorAll('.hero-slide');
        var dots = document.querySelectorAll('.hero-dot');
        var cur = 0;

        function goTo(n) {
          slides[cur].style.opacity = '0';
          dots[cur].style.opacity = '0.4';
          cur = (n + slides.length) % slides.length;
          slides[cur].style.opacity = '1';
          dots[cur].style.opacity = '1';
        }

        dots.forEach(function (dot, i) {
          dot.addEventListener('click', function () {
            goTo(i);
          });
        });

        setInterval(function () {
          goTo(cur + 1);
        }, 4000);
      })();
    </script>

    <!-- Category strip -->
    <section class="bg-white border-b border-gray-100 py-6 px-4 md:px-10">
      <div class="container mx-auto">
        <h2 class="text-base md:text-lg font-bold mb-5 text-gray-800">What's on your mind?</h2>
        <div class="grid grid-cols-4 sm:grid-cols-8 gap-2 md:gap-3">
          <button class="category-pill active" data-category="all">
            <div class="cat-card">
              <img src="/img/cat-all.jpg" alt="All" />
              <div class="cat-label">All</div>
            </div>
          </button>

          <button class="category-pill" data-category="north-indian">
            <div class="cat-card">
              <img src="/img/north-food.jpg" alt="North Indian" />
              <div class="cat-label">North Indian</div>
            </div>
          </button>

          <button class="category-pill" data-category="south-indian">
            <div class="cat-card">
              <img src="/img/south-food.jpg" alt="South Indian" />
              <div class="cat-label">South Indian</div>
            </div>
          </button>

          <button class="category-pill" data-category="pizza">
            <div class="cat-card">
              <img src="/img/piz1.jpg" alt="Pizza" />
              <div class="cat-label">Pizza</div>
            </div>
          </button>

          <button class="category-pill" data-category="burgers">
            <div class="cat-card">
              <img src="/img/burger-food.jpg" alt="Burgers" />
              <div class="cat-label">Burgers</div>
            </div>
          </button>

          <button class="category-pill" data-category="meals">
            <div class="cat-card">
              <img src="/img/meal-food.jpg" alt="Meals" />
              <div class="cat-label">Meals</div>
            </div>
          </button>

          <button class="category-pill" data-category="drinks">
            <div class="cat-card">
              <img src="/img/drinks.jpg" alt="Drinks" />
              <div class="cat-label">Drinks</div>
            </div>
          </button>

          <button class="category-pill" data-category="desserts">
            <div class="cat-card">
              <img src="/img/desert.jpg" alt="Desserts" />
              <div class="cat-label">Desserts</div>
            </div>
          </button>
        </div>
      </div>
    </section>

    <section class="menu container mx-auto py-8 px-4 md:px-10">
      <!-- Search & filter bar -->
      <div class="mb-6">
        <h1 class="text-xl font-bold mb-3">All Items</h1>
        <div class="flex flex-wrap gap-2">
          <input
            id="menu-search"
            type="text"
            placeholder="Search food…"
            class="border border-gray-300 rounded-full px-4 py-2 text-sm flex-1 min-w-0 focus:outline-none focus:border-orange-400"
          />
          <select
            id="price-sort"
            class="border border-gray-300 rounded-full px-4 py-1.5 text-sm focus:outline-none focus:border-orange-400"
          >
            <option value="">Sort by Price</option>
            <option value="asc">Price: Low → High</option>
            <option value="desc">Price: High → Low</option>
          </select>
        </div>
        <span id="no-results" class="text-gray-400 text-sm hidden mt-2 block"
          >No items match your search.</span
        >
      </div>

      <div
        id="menu-grid"
        class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4 md:gap-x-6 md:gap-y-12"
      >
        <% allItems.forEach((item)=>{ %> <% const available = item.isAvailable !== false; %>
        <div
          class="item-card relative flex sm:block items-center gap-4 bg-white sm:bg-transparent rounded-xl sm:rounded-none shadow-sm sm:shadow-none p-3 sm:p-0 <%= !available ? 'opacity-60' : '' %>"
          data-name="<%= item.name.toLowerCase() %>"
          data-size="<%= item.size.toLowerCase() %>"
          data-price="<%= item.price %>"
          data-category="<%= (item.category || 'other').toLowerCase() %>"
        >
          <!-- Image wrapper — fixed size on mobile, full-width on sm+ -->
          <div class="relative flex-shrink-0 w-24 h-24 sm:w-full sm:h-40 sm:mb-4">
            <!-- Veg / Non-veg dot -->
            <div
              class="absolute top-1 left-1 z-10 w-4 h-4 rounded border-2 <%= item.isVeg === false ? 'border-red-600' : 'border-green-600' %> flex items-center justify-center bg-white"
            >
              <div
                class="w-2 h-2 rounded-sm <%= item.isVeg === false ? 'bg-red-600' : 'bg-green-600' %>"
              ></div>
            </div>

            <img
              class="w-full h-full object-cover rounded-lg sm:rounded-none sm:object-contain sm:mx-auto"
              src="/img/<%=item.image%>"
              alt="<%= item.name %>"
            />

            <!-- Sold-out badge on image -->
            <% if (!available) { %>
            <div
              class="absolute inset-0 flex items-center justify-center rounded-lg sm:rounded-none"
            >
              <span class="bg-gray-800 text-white text-xs px-2 py-0.5 rounded-full font-semibold"
                >Sold Out</span
              >
            </div>
            <% } %>
          </div>

          <!-- Content -->
          <div class="flex-1 min-w-0 sm:text-center">
            <!-- Bestseller badge: inline on mobile, absolute on sm+ -->
            <% if (item.isPopular) { %>
            <span
              class="inline-block sm:absolute sm:top-2 sm:right-2 mb-1 sm:mb-0 bg-orange-500 text-white text-xs px-2 py-0.5 rounded-full font-semibold"
              >&#9733; Bestseller</span
            >
            <% } %>

            <h2 class="text-sm sm:text-base md:text-lg font-semibold mb-1 sm:mb-3 truncate">
              <%= item.name %>
            </h2>
            <p class="text-xs text-gray-400 mb-1 sm:mb-2">
              <%= item.grams %>g &nbsp;·&nbsp; <%= item.calories %> kcal
            </p>

            <!-- Star rating -->
            <%
              const full  = Math.floor(item.rating);
              const half  = (item.rating - full) >= 0.5 ? 1 : 0;
              const empty = 5 - full - half;
            %>
            <div class="flex items-center gap-0.5 mb-1 sm:mb-2">
              <% for(let i=0;i<full;i++) { %>
                <svg class="w-3 h-3 text-orange-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <% } %>
              <% if(half) { %>
                <svg class="w-3 h-3" viewBox="0 0 20 20"><defs><linearGradient id="half-<%=item._id%>"><stop offset="50%" stop-color="#fb923c"/><stop offset="50%" stop-color="#d1d5db"/></linearGradient></defs><path fill="url(#half-<%=item._id%>)" d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <% } %>
              <% for(let i=0;i<empty;i++) { %>
                <svg class="w-3 h-3 text-gray-300" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <% } %>
              <span class="text-xs text-gray-500 ml-1 font-medium"><%= item.rating.toFixed(1) %></span>
            </div>

            <div class="flex items-center justify-between sm:justify-around mt-2 sm:mt-4">
              <span class="font-bold text-sm sm:text-base md:text-lg"
                >&#8377;<%= item.price %></span
              >
              <% if (available) { %>
              <button
                data-items="<%=JSON.stringify(item)%>"
                class="add-to-cart py-1 px-3 sm:px-5 rounded-full font-bold text-xs sm:text-sm"
              >
                + Add
              </button>
              <% } else { %>
              <button
                disabled
                class="py-1 px-3 rounded-full font-bold text-gray-400 border border-gray-300 cursor-not-allowed text-xs sm:text-sm"
              >
                Sold Out
              </button>
              <% } %>
            </div>
          </div>
        </div>
        <% }) %>
      </div>

      <!-- Pagination -->
      <div id="pagination" class="flex items-center justify-center gap-1 mt-10 flex-wrap"></div>
    </section>

    <style>
      .pg-btn {
        min-width: 36px;
        height: 36px;
        padding: 0 10px;
        border-radius: 8px;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #374151;
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.15s, color 0.15s, border-color 0.15s;
      }
      .pg-btn:hover:not(:disabled) {
        background: #fff3ee;
        border-color: #FE5F1E;
        color: #FE5F1E;
      }
      .pg-btn.active {
        background: #FE5F1E;
        border-color: #FE5F1E;
        color: #fff;
      }
      .pg-btn:disabled {
        opacity: 0.35;
        cursor: not-allowed;
      }
      .pg-dots {
        color: #9ca3af;
        font-size: 0.875rem;
        padding: 0 4px;
        line-height: 36px;
      }
    </style>

    <script>
      var searchInput  = document.getElementById('menu-search');
      var priceSort    = document.getElementById('price-sort');
      var noResults    = document.getElementById('no-results');
      var menuGrid     = document.getElementById('menu-grid');
      var paginationEl = document.getElementById('pagination');

      var activeCategory = 'all';
      var currentPage    = 1;
      var matchingCards  = [];

      var PAGE_DESKTOP = 20;
      var PAGE_MOBILE  = 10;

      function pageSize() {
        return window.innerWidth >= 768 ? PAGE_DESKTOP : PAGE_MOBILE;
      }

      // Build the matchingCards array from current filter state
      function applyFilters() {
        var query = searchInput.value.toLowerCase().trim();

        matchingCards = [];
        document.querySelectorAll('.item-card').forEach(function (card) {
          var nameMatch = !query || card.dataset.name.includes(query);
          var catMatch  = activeCategory === 'all' || card.dataset.category === activeCategory;
          if (nameMatch && catMatch) matchingCards.push(card);
        });

        currentPage = 1;
        noResults.classList.toggle('hidden', matchingCards.length > 0);
        renderPage();
      }

      // Show only the cards for the current page
      function renderPage() {
        var ps    = pageSize();
        var start = (currentPage - 1) * ps;
        var end   = start + ps;

        document.querySelectorAll('.item-card').forEach(function (c) {
          c.style.display = 'none';
        });
        matchingCards.slice(start, end).forEach(function (c) {
          c.style.display = '';
        });

        renderPagination();
      }

      function renderPagination() {
        var ps         = pageSize();
        var total      = matchingCards.length;
        var totalPages = Math.ceil(total / ps);

        paginationEl.innerHTML = '';
        if (totalPages <= 1) return;

        function btn(label, page, isActive, disabled) {
          var b = document.createElement('button');
          b.className = 'pg-btn' + (isActive ? ' active' : '');
          b.disabled  = disabled;
          b.innerHTML = label;
          b.addEventListener('click', function () { goToPage(page); });
          return b;
        }

        function dots() {
          var s = document.createElement('span');
          s.className = 'pg-dots';
          s.textContent = '…';
          return s;
        }

        // Prev
        paginationEl.appendChild(btn('&#8592;', currentPage - 1, false, currentPage === 1));

        var start = Math.max(1, currentPage - 2);
        var end   = Math.min(totalPages, currentPage + 2);

        if (start > 1) {
          paginationEl.appendChild(btn(1, 1, false, false));
          if (start > 2) paginationEl.appendChild(dots());
        }
        for (var i = start; i <= end; i++) {
          paginationEl.appendChild(btn(i, i, i === currentPage, false));
        }
        if (end < totalPages) {
          if (end < totalPages - 1) paginationEl.appendChild(dots());
          paginationEl.appendChild(btn(totalPages, totalPages, false, false));
        }

        // Next
        paginationEl.appendChild(btn('&#8594;', currentPage + 1, false, currentPage === totalPages));
      }

      function goToPage(page) {
        var ps         = pageSize();
        var totalPages = Math.ceil(matchingCards.length / ps);
        if (page < 1 || page > totalPages) return;
        currentPage = page;
        renderPage();
        document.querySelector('section.menu').scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      // Price sort — reorders cards in the DOM then re-filters
      priceSort.addEventListener('change', function () {
        var dir = this.value;
        if (!dir) return;
        var all = Array.from(document.querySelectorAll('.item-card'));
        all.sort(function (a, b) {
          var pa = parseInt(a.dataset.price, 10);
          var pb = parseInt(b.dataset.price, 10);
          return dir === 'asc' ? pa - pb : pb - pa;
        });
        all.forEach(function (c) { menuGrid.appendChild(c); });
        applyFilters();
      });

      searchInput.addEventListener('input', applyFilters);

      document.querySelectorAll('.category-pill').forEach(function (pill) {
        pill.addEventListener('click', function () {
          document.querySelectorAll('.category-pill').forEach(function (p) {
            p.classList.remove('active');
          });
          this.classList.add('active');
          activeCategory = this.dataset.category;
          applyFilters();
        });
      });

      // Re-render on resize so page size switches between 10 and 20
      var resizeTimer;
      window.addEventListener('resize', function () {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(function () {
          currentPage = 1;
          renderPage();
        }, 200);
      });

      // Initial render
      applyFilters();
    </script>

    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="/app.js"></script>
    <%- include('./partials/footer.ejs') %>
  </body>
</html>
